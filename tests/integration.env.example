# Copy to tests/integration.env (git-ignored) and fill in real values, then:
#   set -a; . tests/integration.env; set +a; composer test:integration

# Use the production base URL only when tracking a real production shipment;
# otherwise leave it pointed at the test ("kindergarden") environment.
POST_IT_TEST_BASE_URL="https://apid.gp.posteitaliane.it/dev/kindergarden"

POST_IT_TEST_SCOPE="api://8f0f2c58-19a8-45ef-9f9e-8bcb0acc7657/.default"
POST_IT_TEST_CLIENT_ID=""
POST_IT_TEST_CLIENT_SECRET=""
POST_IT_TEST_GRANT_TYPE="client_credentials"

# Waybill number to track.
POST_IT_TEST_WAYBILL="ZA123456789IT"

# Optional: enables the live waybill-creation test.
# POST_IT_TEST_COST_CENTER="CDC-..."
# POST_IT_TEST_PRODUCT="APT000901"
